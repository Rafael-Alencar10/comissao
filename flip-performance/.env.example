# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e configure os valores

# Banco de dados PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Chave secreta para JWT (gere uma forte)
JWT_SECRET="sua-chave-secreta-forte-aqui"

# ID da aplicação
VITE_APP_ID="flip-performance-prod"

# Ambiente
NODE_ENV="production"

# URLs do OAuth (substitua pela URL do Render)
OAUTH_SERVER_URL="https://seu-app.render.com"
VITE_OAUTH_PORTAL_URL="https://seu-app.render.com"

# Analytics (opcional)
VITE_ANALYTICS_ENDPOINT="https://seu-app.render.com"
VITE_ANALYTICS_WEBSITE_ID="prod"

# Autenticação
DISABLE_AUTH=false
VITE_DISABLE_AUTH=false